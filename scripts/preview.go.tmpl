// preview.go.tmpl — the standalone preview + frame-renderer scaffold.
//
// Copy this to cmd/preview/main.go in your animation module and wire render()
// to your animation. It gives you both loops from craft.md:
//
//	go run ./cmd/preview            # inner loop: live, in colour, Ctrl-C to quit
//	go run ./cmd/preview frames 3   # dump N frames to stdout (structure + the
//	                                 # headless colour check — pipe through
//	                                 # `cat -v` to see the raw SGR bytes)
package main

import (
	"fmt"
	"os"
	"strconv"
	"time"
	// TODO: import your animation package, e.g.
	//   anim "github.com/you/yourrepo/plasma"
)

func main() {
	const w, h = 80, 24

	// --- wire render() to your animation — pick ONE shape --------------------
	//
	// pure & free-running (frame N from N alone):
	//
	//	render := func(tick int) (string, bool) { return anim.Frame(w, h, tick), false }
	//
	// stateful or resolving (construct once here, then advance each tick — this
	// is why render is a closure and not a top-level func: it closes over `a`):
	//
	//	a := anim.New(w, h /*, seed … */)
	//	render := func(tick int) (string, bool) { a.Update(tick); return a.View(w, h), a.Done() }
	//
	render := func(tick int) (frame string, done bool) {
		panic("wire render() to your animation (see the comment above)")
	}
	// ------------------------------------------------------------------------

	if len(os.Args) > 1 && os.Args[1] == "frames" {
		n := 3
		if len(os.Args) > 2 {
			if v, err := strconv.Atoi(os.Args[2]); err == nil && v > 0 {
				n = v
			}
		}
		for tick := 0; tick < n; tick++ {
			frame, _ := render(tick)
			fmt.Printf("--- frame %d ---\n%s\n", tick, frame)
		}
		return
	}

	fmt.Print("\x1b[?25l")       // hide cursor
	defer fmt.Print("\x1b[?25h") // restore on exit
	for tick := 0; ; tick++ {
		frame, done := render(tick)
		fmt.Printf("\x1b[H%s", frame) // home + paint
		if done {
			fmt.Println()
			return
		}
		time.Sleep(time.Second / 30)
	}
}
